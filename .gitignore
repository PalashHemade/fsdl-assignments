# Environment files (containing secrets)
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.test
**/.env.production

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
Thumbs.db
*.tmp
*.temp
