**/node_modules/
**/venv/
**/.venv/
**/env/
**/ENV/

# Python cache and compile files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Next.js and frontend builds
**/.next/
**/out/
**/dist/
**/build/
